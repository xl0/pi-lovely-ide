{
	"name": "pi-lovely-ide-vscode",
	"displayName": "Pi Lovely IDE",
	"description": "Pi IDE Protocol bridge for VS Code",
	"version": "0.1.0",
	"publisher": "xl0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/xl0/pi-lovely-ide.git",
		"directory": "ide-plugins/vscode"
	},
	"type": "module",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/ide-plugins/vscode/src/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "pi-lovely-ide.mentionSelection",
				"title": "Pi: Mention Selection"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p .",
		"vscode:prepublish": "npm run compile",
		"package": "vsce package"
	},
	"dependencies": {
		"typebox": "^1.2.2",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.100.0",
		"@types/ws": "^8.5.0",
		"@vscode/vsce": "^3.0.0",
		"typescript": "^5.5.0"
	}
}
