{
	"name": "@xl0/pi-lovely-ide",
	"version": "0.3.2",
	"keywords": [
		"pi-package",
		"vscode",
		"claude code",
		"neovim"
	],
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/xl0/pi-lovely-ide#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xl0/pi-lovely-ide.git"
	},
	"files": [
		"extensions/",
		"packages/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "tsgo --noEmit && cd ide-plugins/vscode && bun run typecheck",
		"check": "bun run typecheck && cd ide-plugins/vscode && bun run check && cd ../.. && bun run biome:check",
		"release": "npm publish --access public",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@earendil-works/pi-coding-agent": "^0.80.10",
		"@types/node": "^25.9.2",
		"@typescript/native-preview": "^7.0.0-dev.20260606.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "^0.80.10"
	},
	"pi": {
		"extensions": [
			"./extensions"
		]
	},
	"dependencies": {
		"@xl0/pi-lovely-config": "^0.1.2",
		"undici": "^8.4.0",
		"valibot": "^1.4.0"
	}
}
