{
	"name": "@xl0/pi-lovely-ide",
	"version": "0.1.1",
	"keywords": [
		"pi-package",
		"vscode",
		"claude code",
		"neovim"
	],
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/xl0/pi-lovely-ide#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xl0/pi-lovely-ide.git"
	},
	"files": [
		"extensions/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"check": "bun run typecheck && bun run biome:check",
		"release": "npm publish --access public",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/node": "^24.12.4",
		"@typescript/native-preview": "^7.0.0-dev.20260502.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"pi": {
		"extensions": [
			"./extensions"
		]
	},
	"dependencies": {
		"typebox": "^1.1.39",
		"undici": "^8.3.0"
	}
}
